# ==========================================
# 1. IDE & Local Configuration (Crucial for VS)
# ==========================================
.vs/                         # Visual Studio local cache, solution options, and performance data
.vs-*/                       # Versioned local VS directories
out/                         # Default local CMake build output folder for VS
_vcpkg/                      # Local vcpkg artifacts if embedded in repo
vcpkg_installed/             # Cached dependencies per build profile
hardware_connections.json    # Avoid leaking private SSH keys/connection profiles!
out/
*.clangd

# Other IDEs
.idea/
.vscode/

# ==========================================
# 2. Build & Generator Artifacts
# ==========================================
build/
build-*/
Build/
bin/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json
_deps/

# ==========================================
# 3. Compiled Binaries & Core Dumps
# ==========================================
*.o
*.obj
*.so
*.dylib
*.dll
*.exe
*.out
*.a
*.lib

# ==========================================
# 4. Debugging & Performance Profiling Symbols
# ==========================================
*.pdb
*.ilk
*.dwo
*.suo
*.user
*.userosscache
*.sln.docstates

# ==========================================
# 5. OS & Logging Garbage
# ==========================================
.DS_Store
Thumbs.db
Desktop.ini
*.log
*.tmp
*.bak
*.swp
/.vs
/external
